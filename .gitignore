# ============================================================================
# TMP — Tournament Manager Pro
# .gitignore
# ============================================================================

# --- Dependencies ---
/node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js build output ---
/.next/
/out/
/build

# --- Testing ---
/coverage

# --- Environment variables ---
.env
.env.*
!.env.example

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- AI agent files ---
AGENTS.md
CLAUDE.md

# --- Misc ---
*.pem
.vercel

# --- Test Files ---
*.json